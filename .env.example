COMPOSE_PROJECT_NAME=pariti

TZ=Europe/Berlin

PROXY_NETWORK=traefik_network
DOMAIN=localhost

ADMIN_EMAIL=admin@example.com

DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_PASSWORD=secret
DATABASE_USERNAME=pariti
DATABASE_NAME=pariti
DATABASE_URL=postgres://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# SAML SSO (habidat-auth)
SAML_IDP_ISSUER=https://user.habidat.org
SAML_IDP_ENTRY_POINT=https://user.habidat.org/saml/sso
SAML_IDP_CERT=
SAML_SP_ENTITY_ID=http://localhost:3000/api/auth/sso/saml2/sp/metadata
SAML_DOMAIN=localhost
SAML_GROUPS_CLAIM_KEY=groups
SAML_MAPPING_ID=nameID
SAML_MAPPING_EMAIL=email
SAML_MAPPING_NAME=displayName
